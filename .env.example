# Supabase — used by all backend API handlers via lib/supabase.ts
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — used by api/interpret-signals.ts
OPENAI_API_KEY=

# Sentry — used by lib/sentry.ts (optional; if unset, error tracking is disabled)
# Note: the variable name is SENTRY_DSN (not SENTRY_DNS)
SENTRY_DSN=

# Cron and API protection — enforced in all pipeline handlers and read endpoints via lib/withCronAuth.ts
# Vercel sends this automatically as Bearer token when triggering cron jobs.
# Must also be set in the radar-ui project to allow the UI to call the backend.
CRON_SECRET=
