# Base URL of the Vercel runtime backend — used by lib/api.ts and app/api/competitor-detail/route.ts
# This is a SEPARATE Vercel project from the radar-ui frontend.
# Production: set to the backend runtime URL (e.g. https://metrivant-runtime.vercel.app or a custom api.* subdomain)
# Development: set to http://localhost:3001 or leave unset to use the production runtime fallback.
RADAR_API_BASE_URL=

# Shared API secret — must match the backend's CRON_SECRET value.
# Used server-side only (Next.js server components and API routes); never sent to the browser.
# Required in production: the backend rejects requests without a valid Authorization header.
CRON_SECRET=

# Supabase — required for auth (get from Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog — optional, for event tracking
# NEXT_PUBLIC_POSTHOG_KEY is used by client components and some API routes
# POSTHOG_API_KEY is used by server-side API routes (check-signals, generate-brief, etc.)
# Both should be set to your PostHog project API key
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_API_KEY=

# Resend — optional, for welcome emails and weekly briefs
RESEND_API_KEY=
# Override sender address for all outbound emails (optional)
# When unset, each flow uses its canonical address: hello@, alerts@, or briefs@metrivant.com
FROM_EMAIL=

# OpenAI — required for weekly intelligence brief generation
OPENAI_API_KEY=
# Cap OpenAI calls per cron run to prevent runaway costs at scale (default: 100)
# Lower this during cost-sensitive periods (e.g. OPENAI_MAX_ORGS_PER_RUN=10)
OPENAI_MAX_ORGS_PER_RUN=

# Sentry — optional, for server-side error tracking
# Get DSN from Sentry project settings → Client Keys
SENTRY_DSN=

# Supabase service role — required for generate-brief (bypasses RLS to send emails to all users)
# Get from Supabase project settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used by auth signout redirect and auth callback
# Set to https://metrivant.com for production
NEXT_PUBLIC_SITE_URL=https://metrivant.com

# Stripe — required for billing (checkout, webhooks, portal)
# Get from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Get from Stripe Dashboard → Developers → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET=
# Get from Stripe Dashboard → Products → Price IDs
STRIPE_ANALYST_PRICE_ID=
STRIPE_PRO_PRICE_ID=
