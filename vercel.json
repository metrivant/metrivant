{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/fetch-snapshots.ts":                { "maxDuration": 30 },
    "api/interpret-signals.ts":              { "maxDuration": 30 },
    "api/synthesize-movement-narratives.ts": { "maxDuration": 90 },
    "api/generate-radar-narratives.ts":      { "maxDuration": 90 },
    "api/generate-sector-intelligence.ts":   { "maxDuration": 90 },
    "api/suggest-selector-repairs.ts":       { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/fetch-snapshots?page_class=ambient",    "schedule": "0,30 * * * *"  },
    { "path": "/api/fetch-snapshots?page_class=high_value", "schedule": "2 * * * *"     },
    { "path": "/api/fetch-snapshots?page_class=standard",   "schedule": "4 */3 * * *"   },
    { "path": "/api/extract-sections",                       "schedule": "15,45 * * * *" },
    { "path": "/api/build-baselines",                        "schedule": "17,47 * * * *" },
    { "path": "/api/detect-diffs",                           "schedule": "19,49 * * * *" },
    { "path": "/api/detect-signals",                         "schedule": "21,51 * * * *" },
    { "path": "/api/detect-ambient-activity",                "schedule": "23,53 * * * *" },
    { "path": "/api/update-pressure-index",                  "schedule": "25,55 * * * *" },
    { "path": "/api/ingest-feeds",                           "schedule": "10 * * * *"    },
    { "path": "/api/ingest-careers",                         "schedule": "11 * * * *"    },
    { "path": "/api/promote-feed-signals",                   "schedule": "12 * * * *"    },
    { "path": "/api/promote-careers-signals",                "schedule": "13 * * * *"    },
    { "path": "/api/interpret-signals",                      "schedule": "28 * * * *"    },
    { "path": "/api/update-signal-velocity",                 "schedule": "50 * * * *"    },
    { "path": "/api/detect-movements",                       "schedule": "55 * * * *"    },
    { "path": "/api/synthesize-movement-narratives",         "schedule": "30 * * * *"    },
    { "path": "/api/generate-radar-narratives",              "schedule": "45 * * * *"    },
    { "path": "/api/generate-sector-intelligence",           "schedule": "0 7 * * 1,3,5" },
    { "path": "/api/promote-baselines",                      "schedule": "0 2 * * *"     },
    { "path": "/api/retention",                              "schedule": "0 3 * * *"     },
    { "path": "/api/suggest-selector-repairs",               "schedule": "0 4 * * *"     },
    { "path": "/api/watchdog",                               "schedule": "*/15 * * * *"  }
  ]
}
